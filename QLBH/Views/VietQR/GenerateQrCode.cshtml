@{
    ViewData["Title"] = "Thanh toán VietQR";


    var orderCode = ViewBag.OrderCode;
    var amount = ViewBag.Amount;
    var accountName = ViewBag.AccountName;
    var accountNumber = ViewBag.AccountNumber;
    var email = ViewBag.Email;
    var phone = ViewBag.Phone;
    var name = ViewBag.Name;

    var bankId = "970422";
    var template = "compact2";


    var addInfo = System.Net.WebUtility.UrlEncode(orderCode.ToString());


    var vietQrUrl =
    $"https://img.vietqr.io/image/{bankId}-{accountNumber}-{template}.png?amount={amount}&addInfo={addInfo}";
}

<div
    style="text-align: center; border: 1px solid #ccc; padding: 20px; border-radius: 8px; max-width: 400px; margin: auto; margin-top: 75px; font-family: Arial, sans-serif;">
    <h3>Thanh toán đơn hàng qua VietQR</h3>
    <p>Vui lòng quét mã QR dưới đây để hoàn tất thanh toán.</p>

    <img src="@vietQrUrl" width="300" alt="Mã QR thanh toán đơn hàng @orderCode"
        style="max-width: 100%; height: auto;" />

    <div style="margin-top: 20px; padding-top: 30px; border-top: 1px solid #eee;">
        <p style="font-weight: bold; font-size: 1.1em; color: #333; text-align: center;">THÔNG TIN CHUYỂN KHOẢN</p>
        <div style="text-align: left; margin: 0 auto; max-width: 350px;">
            <p><strong>Ngân hàng:</strong> MB Bank </p>
            <p><strong>Chủ tài khoản:</strong> @accountName</p>
            <div class="info-item">
                <span style="flex-grow: 1;"><strong>Số tài khoản:</strong> @accountNumber</span>
                <button class="copy-btn" onclick="copyToClipboard('@accountNumber')" title="Copy số tài khoản">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                        class="bi bi-clipboard" viewBox="0 0 16 16">
                        <path
                            d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z" />
                        <path
                            d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z" />
                    </svg>
                </button>
            </div>
            <div class="info-item">
                <span style="flex-grow: 1;"><strong>Số tiền:</strong> <span
                        style="color: #d9534f; font-weight: bold;">@amount.ToString("N0") VNĐ</span></span>
                <button class="copy-btn" onclick="copyToClipboard('@amount')" title="Copy số tiền">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                        class="bi bi-clipboard" viewBox="0 0 16 16">
                        <path
                            d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z" />
                        <path
                            d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z" />
                    </svg>
                </button>
            </div>
            <div class="info-item">
                <span style="flex-grow: 1;"><strong>Nội dung:</strong> <span
                        style="color: #0275d8; font-weight: bold;">@orderCode</span></span>
                <button class="copy-btn" onclick="copyToClipboard('@orderCode')" title="Copy nội dung">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                        class="bi bi-clipboard" viewBox="0 0 16 16">
                        <path
                            d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z" />
                        <path
                            d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z" />
                    </svg>
                </button>
            </div>
        </div>
    </div>


    <div style="margin-top: 20px; font-size: 0.9em; color: #777;">
        <p>Sau khi chuyển khoản thành công, hệ thống sẽ tự động cập nhật trạng thái đơn hàng của bạn.</p>
        <p>Trang sẽ tự động chuyển hướng sau khi thanh toán được xác nhận.</p>
    </div>
    <div id="toast" class="toast">Đã sao chép!</div>
</div>
<style>
    .info-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
    }

    .copy-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0 5px;
        display: inline-flex;
        align-items: center;
        color: #555;
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .copy-btn:hover {
        opacity: 1;
    }

    .copy-btn svg {
        width: 16px;
        height: 16px;
    }

    .toast {
        visibility: hidden;
        min-width: 120px;
        background-color: #333;
        color: #fff;
        text-align: center;
        border-radius: 2px;
        padding: 16px;
        position: fixed;
        z-index: 1;
        left: 50%;
        transform: translateX(-50%);
        bottom: 30px;
        font-size: 17px;
        border-radius: 8px;
    }

    .toast.show {
        visibility: visible;
        -webkit-animation: fadein 0.5s, fadeout 0.5s 2.5s;
        animation: fadein 0.5s, fadeout 0.5s 2.5s;
    }
</style>

<div style="text-align: center; margin-top: 20px;">
    <form action="/VietQR/CancelOrder" method="post">
        <input type="hidden" name="payosOrderCode" value="@ViewBag.PayOSOrderCode" />
        <button type="submit" class="btn btn-outline-danger">Hủy và quay về giỏ hàng</button>
    </form>
</div>

<script>
    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(function () {
            showToast();
        }, function (err) {
            console.error('Không thể sao chép: ', err);
        });
    }

    function showToast() {
        var toast = document.getElementById("toast");
        toast.className = "toast show";
        setTimeout(function () { toast.className = toast.className.replace("show", ""); }, 3000);
    }
    (function () {
        const payosOrderCode = '@ViewBag.PayOSOrderCode';
        const email = '@email';
        const phone = '@phone';
        const name = '@name';
        const checkStatusUrl = `/VietQR/CheckStatus?payosOrderCode=${payosOrderCode}`;
        const successUrl = `/VietQR/Success`;
        const cancelUrl = '/Cart?payment=cancel';

        let pollingInterval;

        const checkPaymentStatus = () => {
            console.log("Checking status for PayOS order code:", payosOrderCode);
            fetch(checkStatusUrl)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`Network response was not ok. Status: ${response.status}`);
                    }
                    return response.json();
                })
                .then(data => {
                    console.log("Status received:", data.status);
                    if (data.status === 'paid') {
                        clearInterval(pollingInterval);
                        alert('Thanh toán thành công! Bạn sẽ được chuyển hướng đến lịch sử đơn hàng.');
                        fetch(successUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                email: email,
                                name: name,
                                phone: phone,
                                status: 'success'
                            })
                        })
                            .then(response => {
                                if (!response.ok) {
                                    throw new Error(`Network response was not ok. Status: ${response.status}`);
                                }
                                return response.json();
                            })
                            .then(data => {
                                console.log(data.returnUrl)
                                if (data) window.location.href = data.returnUrl
                            })
                            .catch(error => {
                                console.error(error)
                            })
                    } else if (data.status === 'cancelled') {
                        clearInterval(pollingInterval);
                        alert('Thanh toán đã bị hủy. Bạn sẽ được chuyển hướng về giỏ hàng.');
                        window.location.href = cancelUrl;
                    }
                    // If status is 'pending' or 'notfound', do nothing and let the interval run again.
                })
                .catch(error => {
                    console.error('Error checking payment status:', error);
                    // Stop polling if there's a persistent error with the check itself.
                    clearInterval(pollingInterval);
                });
        };

        // Poll every 3 seconds.
        pollingInterval = setInterval(checkPaymentStatus, 3000);

        // Stop polling after 10 minutes (600,000 milliseconds) to prevent indefinite requests.
        setTimeout(() => {
            clearInterval(pollingInterval);
            console.log('Stopped polling after 10 minutes.');
        }, 600000);
    })();
</script>