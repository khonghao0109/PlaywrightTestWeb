@using PagedList.Core.Mvc
@model PagedList.Core.IPagedList<MyWebApp.Models.ProductModel>
<div class="row">
	
		<div class="col-sm-3 sidebar-container">
			@Html.Partial("_SidebarPartial")
		</div>

		<div class="col-sm-9 padding-right product-content">


			<!-- Recommend Products Section - Chỉ hiển thị khi user đã mua sản phẩm -->
			@{
				var recommendedProducts = ViewBag.RecommendedProducts as IEnumerable<ProductModel>;
				var hasUserPurchased = (bool?)ViewBag.HasUserPurchased ?? false;
			}
			@if (hasUserPurchased && recommendedProducts != null && recommendedProducts.Any())
			{
				<div class="recommended_items">
					<h2 class="title text-center">SẢN PHẨM BẠN CÓ THỂ THÍCH</h2>
					<div id="recommended-item-carousel" class="carousel-inner" data-ride="carousel">
						<div class="carousel-inner">
							<div class="item active">
								@foreach (var recommendedProduct in recommendedProducts)
								{
									<div class="col-xs-6 col-md-4 col-lg-3 product-card-wrapper">
										<div class="product-card">
											<a asp-action="Detail" asp-controller="Product"
												asp-route-Id="@recommendedProduct.Id" class="product-link">
												<!-- Product Image -->
												<div class="product-image-wrapper-new">
													<img src="~/media/products/@recommendedProduct.Image"
														alt="@recommendedProduct.Name" class="product-main-image" />
												</div>

												<!-- Product Info -->
												<div class="product-details-new">
													<!-- Category Badge -->
													<div class="product-category-badge-new">
														@recommendedProduct.Category?.Name</div>

													<!-- Product Title -->
													<h3 class="product-name-new">
														@recommendedProduct.Name</h3>

													<!-- Price Section -->
													<div class="product-price-section">
														<span class="product-price-old">@recommendedProduct.RealPrice.ToString("#,##0") ₫</span>
														<span
															class="product-price-new">@recommendedProduct.Price.ToString("#,##0")
															₫</span>
													</div>

													<!-- Add to Cart Button -->
													<button type="button" class="btn-add-to-cart-circle ajax-add-to-cart"
														data-id="@recommendedProduct.Id">
														<i class="fa fa-shopping-cart"></i>
													</button>
												</div>
											</a>
										</div>
									</div>
								}
							</div>
						</div>
					</div>
				</div>
			}

			<div class="features_items"><!--features_items-->
				<h2 class="title text-center">SẢN PHẨM MỚI RA MẮT</h2>
				<div class="products-grid-container">
					@foreach (var item in Model)
					{
						<div class="col-xs-6 col-md-4 col-lg-3 product-card-wrapper">
							<div class="product-card">
								<a asp-action="Detail" asp-controller="Product" asp-route-Id="@item.Id"
									class="product-link">
									<!-- Product Image -->
									<div class="product-image-wrapper-new">
										<img src="~/media/products/@item.Image" alt="@item.Name"
											class="product-main-image" />
									</div>

									<!-- Product Info -->
									<div class="product-details-new">
										<!-- Category Badge -->
										<div class="product-category-badge-new">@item.Category.Name
										</div>

										<!-- Product Title -->
										<h3 class="product-name-new">@item.Name</h3>

										<!-- Price Section -->
										<div class="product-price-section">
											<span class="product-price-old">@item.RealPrice.ToString("#,##0") ₫</span>
											<span class="product-price-new">@item.Price.ToString("#,##0")
												₫</span>
										</div>

										<!-- Add to Cart Button -->
										<button type="button" class="btn-add-to-cart-circle ajax-add-to-cart"
											data-id="@item.Id">
											<i class="fa fa-shopping-cart"></i>
										</button>
									</div>
								</a>
							</div>
						</div>
					}
				</div>
			</div><!--features_items-->
			<div class="row">
				<div class="col-sm-12 text-center">
					<pager class="pager-container" list="@Model" asp-action="Index" asp-controller="Home" />
				</div>
			</div>
		</div>
	
</div>